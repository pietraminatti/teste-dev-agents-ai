# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# GitHub Personal Access Token
# Acesse: GitHub → Settings → Developer Settings → Personal Access Tokens
GITHUB_TOKEN=ghp_your-github-token-here

# URL do repositório GitHub (opcional, pode ser informada no input)
# GITHUB_REPO_URL=https://github.com/usuario/repositorio

# Modelo da OpenAI (opcional)
# OPENAI_MODEL_NAME=gpt-4o-mini
